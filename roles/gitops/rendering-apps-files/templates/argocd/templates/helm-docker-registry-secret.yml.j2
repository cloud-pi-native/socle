{% if dsc.global.dockerAccount.enabled %}
---
apiVersion: v1
kind: Secret
metadata:
  name: helm-docker-registry-secret
  namespace: {{ dsc.argocd.namespace }}
type: Opaque
stringData:
  username: <path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#dockerAccount | jsonPath {.username}>
  password: <path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#dockerAccount | jsonPath {.password}>
{% endif %}

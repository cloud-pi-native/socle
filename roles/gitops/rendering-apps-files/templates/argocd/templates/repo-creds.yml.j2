---
apiVersion: v1
kind: Secret
metadata:
  labels:
    argocd.argoproj.io/secret-type: repo-creds
  name: gitlab
  namespace: {{ dsc.argocd.namespace }}
type: Opaque
stringData:
  password: <path:forge-dso/data/env/{{ dsc_name }}/apps/gitlab/values#gitlabToken>
  url: "https://<path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#domain | jsonPath {.gitlab}>/{{ dsc.global.projectsRootDir | flatten | join ('/') }}"
  username: "root"
---
apiVersion: v1
kind: Secret
metadata:
  labels:
    argocd.argoproj.io/secret-type: repo-creds
  name: oci-dockerhub-creds
  namespace: dso-argocd
stringData:
  url: registry-1.docker.io
  name: bitnamicharts
  type: helm
  enableOCI: "true"
  username: <path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#dockerAccount | jsonPath {.username}>
  password: <path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#dockerAccount | jsonPath {.password}>
{% if dsc.proxy.enabled %}
  proxy: <path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#proxy | jsonPath {.httpProxy}> 
{% endif %}

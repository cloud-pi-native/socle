---
apiVersion: v2
name: nexus
type: application
version: {{ dsc.nexus.chartVersion }}
dependencies:
- name: cpn-cnpg
  alias: cpn-cnpg
  version: {{ dsc.cpnCnpg.chartVersion }}
  repository: {{ dsc.cpnCnpg.helmRepoUrl }}
- name: nexus
  alias: nexus
  version: {{ dsc.nexus.chartVersion }}
  repository: "{{ dsc.nexus.helmRepoUrl if 'oci://' in dsc.nexus.helmRepoUrl else dsc.nexus.helmRepoUrl ~ '/nexus' }}"

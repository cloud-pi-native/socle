namespace: {{ dsc.harbor.namespace }}

harbor:
  expose:
    imagePullPolicy: IfNotPresent
    type: ingress
    ingress:
      className: {{ dsc.ingress.className | default('') }}
      hosts:
        core: <path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#domain | jsonPath {.harbor}>
        notary: <path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#domain | jsonPath {.harborNotary}>
      notary:
        annotations:
{% for key, val in dsc.ingress.annotations.items() %}
          {{ key }}: {{ val }}
{% endfor %}
        labels:
{% for key, val in dsc.ingress.labels.items() %}
          {{ key }}: {{ val }}
{% endfor %}
      harbor:
        annotations:
{% for key, val in dsc.ingress.annotations.items() %}
          {{ key }}: {{ val }}
{% endfor %}
        labels:
{% for key, val in dsc.ingress.labels.items() %}
          {{ key }}: {{ val }}
{% endfor %}
  externalURL: https://<path:forge-dso/data/env/{{ dsc_name }}/apps/common/values#domain | jsonPath {.harbor}>
  persistence:
    enabled: true
    resourcePolicy: keep
    persistentVolumeClaim:
      registry:
        size: "{{ dsc.harbor.pvcRegistrySize }}"
      jobservice:
        jobLog:
          size: "{{ dsc.harbor.pvcJobLogSize }}"
      database:
        size: "{{ dsc.harbor.pvcDatabaseSize }}"
      redis:
        size: "{{ dsc.harbor.pvcRedisSize }}"
      trivy:
        size: "{{ dsc.harbor.pvcTrivySize }}"
  harborAdminPassword: <path:forge-dso/data/env/{{ dsc_name }}/apps/harbor/values#global | jsonPath {.harborAdminPassword}>
  database:
    type: external
    external:
      host: "pg-cluster-harbor-rw"
      port: "5432"
      username: <path:forge-dso/data/env/{{ dsc_name }}/apps/harbor/values#cnpg | jsonPath {.username}>
      password: <path:forge-dso/data/env/{{ dsc_name }}/apps/harbor/values#cnpg | jsonPath {.password}>
      coreDatabase: "registry"
  metrics:
    enabled: {{ dsc.global.metrics.enabled }}
    serviceMonitor:
      enabled: {{ dsc.global.metrics.enabled }}
